#!/bin/bash
# Route Claude Code hooks to the local cms server.
# Reads JSON from stdin, POSTs to the matching /api/hooks/* endpoint.
# On SessionStart, ensures the server is running (via `cms start`).

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
STDIN_DATA=$(cat)

EVENT=$(echo "$STDIN_DATA" | grep -o '"hook_event_name":"[^"]*"' | cut -d'"' -f4)

case "$EVENT" in
  SessionStart)  ENDPOINT="/api/hooks/session-start" ;;
  PreToolUse)    ENDPOINT="/api/hooks/pre-tool-use" ;;
  PostToolUse)   ENDPOINT="/api/hooks/post-tool-use" ;;
  Stop)          ENDPOINT="/api/hooks/stop" ;;
  *)             exit 0 ;;
esac

PLUGIN_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
CMS_BIN="$HOME/.codemyspec/bin/cms"
[ ! -x "$CMS_BIN" ] && [ -x "$PLUGIN_ROOT/bin/cms" ] && CMS_BIN="$PLUGIN_ROOT/bin/cms"

if [ "$EVENT" = "SessionStart" ]; then
  # Install / update the binary if needed. Foreground on first install;
  # background (fire-and-forget) once the binary exists.
  if [ ! -x "$CMS_BIN" ]; then
    "$SCRIPT_DIR/auto-update" 2>/dev/null
    CMS_BIN="$HOME/.codemyspec/bin/cms"
  else
    "$SCRIPT_DIR/auto-update" &>/dev/null &
    disown
  fi

  # Idempotent: `cms start` no-ops if the server is already up, otherwise
  # daemonizes + waits for /health to respond. Exits 0 on success.
  [ -x "$CMS_BIN" ] && "$CMS_BIN" start >/dev/null 2>&1
fi

curl -s -X POST "http://localhost:4003${ENDPOINT}" \
  -H "Content-Type: application/json" \
  -H "X-Working-Dir: $(pwd)" \
  -d "$STDIN_DATA"
